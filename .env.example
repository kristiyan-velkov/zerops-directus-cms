# ═══════════════════════════════════════════════════════════════════════════════
# Directus — Local Development Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and adjust values as needed:
#   cp .env.example .env
#
# In production (Zerops), secrets are auto-generated at import time via
# generateRandomString and injected as env secrets — never stored in files.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Directus Core ─────────────────────────────────────────────────────────────
# Signs all JWTs. Use a long random string. Changing this logs out all users.
SECRET=local-dev-secret-do-not-use-in-production-replace-me

# Must be "true" to acknowledge the BSL 1.1 licence.
ACCEPT_TERMS=true

# Disable anonymous telemetry.
TELEMETRY=false

# Public URL for OAuth callbacks, email links, and CORS.
# For local dev this is always http://localhost:8055.
PUBLIC_URL=http://localhost:8055

# ── Admin Account (bootstrapped on first run) ─────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@directus1

# Static API token — use in scripts/tests instead of a login flow.
ADMIN_TOKEN=local-dev-static-token-replace-me

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DB_CLIENT=pg
DB_HOST=db
DB_PORT=5432
DB_DATABASE=directus
DB_USER=directus
DB_PASSWORD=directus_secret
DB_POOL__MIN=2
DB_POOL__MAX=10

# ── Cache / Pub-Sub (Redis / Valkey) ─────────────────────────────────────────
REDIS_HOST=cache
REDIS_PORT=6379
SYNCHRONIZATION_STORE=redis
# Shared HTTP response cache — all containers share one store via Valkey.
CACHE_ENABLED=true
CACHE_STORE=redis

# ── Object Storage (MinIO → S3-compatible) ────────────────────────────────────
STORAGE_LOCATIONS=s3
STORAGE_S3_DRIVER=s3
STORAGE_S3_KEY=minioadmin
STORAGE_S3_SECRET=minioadmin123
STORAGE_S3_BUCKET=directus-local
# MinIO runs on port 9000 inside docker-compose.
STORAGE_S3_ENDPOINT=http://storage:9000
STORAGE_S3_REGION=us-east-1
# Required: MinIO uses path-style URLs, not virtual-hosted-style.
STORAGE_S3_FORCE_PATH_STYLE=true
STORAGE_S3_ACL=public-read

# ── Email (Mailpit SMTP sink) ─────────────────────────────────────────────────
EMAIL_TRANSPORT=smtp
EMAIL_SMTP_HOST=mailpit
EMAIL_SMTP_PORT=1025
EMAIL_FROM=no-reply@directus.local
